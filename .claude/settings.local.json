{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Git",
      "Npm",
      "Pip",
      "Bash(conda env *)",
      "WebFetch(domain:docs.vllm.ai)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Rm",
      "Ssh",
      "Sudo"
    ],
    "initialPermissionMode": "acceptEdits"
  }
}
